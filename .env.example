# Required secrets
PUBLIC_KEY=""
SEED_PHRASE=""

# Nexus / Ollama endpoints
NEXUS_API_URL="https://nexus.pubky.app"
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="mistral:7b"

# LLM Keyword Prompt
LLM_KEYWORD_PROMPT="From the following text, output between 1 and 3 keywords (into the texte langage) for tagging based on your analysis. RULES: 1) Output ONLY the keywords (1 to 3 depending on content relevance), 2) Separate keywords with semicolons, 3) Replace spaces within keywords with hyphens, but keywords MUST NOT start or end with a hyphen, 4) No numbering, bullets, quotes, or explanations, 5) Each keyword must be a valid, meaningful term without leading or trailing hyphens. Examples: mot1 OR mot1;mot-cle-2 OR mot1;mot-cle-2;mot-cle-3. Text: {{TEXT}}"

# User Messages
TAGKY_MSG_FOLLOW_ACTIVATED="✅ Follow activated. I will process your new posts and publish tags."
TAGKY_MSG_FOLLOW_DEACTIVATED="✅ Follow deactivated. I will no longer process your new posts."
TAGKY_MSG_UNFOLLOW_EXPLANATION="Sorry, I cannot tag this post because follow was deactivated during processing. To reactivate automatic tagging, mention me with \"/tag on\"."
TAGKY_MSG_GUIDANCE_INTRO="ℹ️ To activate tag tracking, post exactly:"
TAGKY_MSG_GUIDANCE_ACTIVATE="/tag on"
TAGKY_MSG_GUIDANCE_SEPARATOR=""
TAGKY_MSG_GUIDANCE_DEACTIVATE_INTRO="To deactivate:"
TAGKY_MSG_GUIDANCE_DEACTIVATE="/tag off"

# Scheduling and logging
TAGKY_FETCH_INTERVAL_MS="5000"
TAGKY_WORKER_INTERVAL_MS="5000"
TAGKY_PUBLISH_INTERVAL_MS="5000"
TAGKY_LOG_LEVEL="info"
TAGKY_QUIET_TAGS="0"
TAGKY_WEB_MONITOR_PORT="3001"